# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hellware?sslmode=require"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"
ADMIN_SETUP_TOKEN="replace-with-one-time-admin-registration-token"
ADMIN_PANEL_PASSWORD="replace-with-admin-panel-password"

# Google Service Account
GOOGLE_CLIENT_EMAIL="service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional Google OAuth Web Client fallback.
# Requires a refresh token; client id + client secret alone cannot access Drive/Sheets server-side.
GOOGLE_OAUTH_PROJECT_ID="google-cloud-project-id"
GOOGLE_OAUTH_CLIENT_ID="google-oauth-web-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="google-oauth-web-client-secret"
GOOGLE_OAUTH_REFRESH_TOKEN="google-oauth-refresh-token"

GOOGLE_SHEETS_ID="spreadsheet-id"
GOOGLE_APPLICATIONS_SHEET="Applications Index"
GOOGLE_PAYMENTS_SHEET="Financial Audit"
GOOGLE_DRIVE_RESUMES_FOLDER_ID="drive-folder-id-for-resumes"
GOOGLE_DRIVE_PAYMENTS_FOLDER_ID="drive-folder-id-for-payment-proofs"

# CORS
FRONTEND_ORIGIN="https://frontend-sooty-gamma-75.vercel.app"
